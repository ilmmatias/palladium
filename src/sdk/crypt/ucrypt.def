    CryptInitializeSha256Hash
    CryptUpdateSha256Hash

    CryptClearSha384Hash
    CryptFinishSha384Hash
    CryptGetSha384Hash
    CryptInitializeSha384Hash
    CryptUpdateSha384Hash

    CryptClearSha512Hash
    CryptFinishSha512Hash
    CryptGetSha512Hash
    CryptInitializeSha512Hash
    CryptUpdateSha512Hash
